# Meridian HR Honeypot — Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env.

# Port configuration (override defaults)
SSH_PORT=22
REDIS_PORT=6379
MONGO_PORT=27017
MYSQL_PORT=3306
LDAP_PORT=389
LDAPS_PORT=636
GC_PORT=3268
KERBEROS_PORT=88
SMB_PORT=445
DASHBOARD_PORT=8080

# Network
BIND_HOST=0.0.0.0

# Optional enrichment APIs
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# Optional: restrict dashboard access
# DASHBOARD_ALLOWED_IPS=10.0.0.0/8,192.168.0.0/16
